# BOCHK 预约监控配置
# 本文件可选；若不提供，也可仅依赖默认值 + BOCHK_* 环境变量启动。
# 环境变量优先级高于本文件。

[proxy]
# SOCKS5 代理地址；留空表示直连（默认）
# 推荐使用 socks5h://，由代理端完成 DNS 解析
# 环境变量：BOCHK_PROXY_URL
url = ""

[monitor]
# 请求间隔（秒），默认 30
# 建议根据网络情况控制在 10-30 秒
# 环境变量：BOCHK_MONITOR_INTERVAL_SECS
interval_secs = 30
# 连续失败多少次后发送 Bark 异常告警，默认 5
# 环境变量：BOCHK_MONITOR_MAX_FAIL_COUNT
max_fail_count = 5

[monitor.schedule]
# 调度模式：half_hour_focus（默认）| fixed
# fixed 模式下只使用 monitor.interval_secs
# 环境变量：BOCHK_MONITOR_SCHEDULE_MODE
mode = "half_hour_focus"

# 常规时段轮询间隔（秒）
# 环境变量：BOCHK_MONITOR_NORMAL_INTERVAL_SECS
normal_interval_secs = 60

# 半点前后聚焦窗口轮询间隔（秒）
# 环境变量：BOCHK_MONITOR_FOCUS_INTERVAL_SECS
focus_interval_secs = 10

# 午夜 00:00-00:05 聚焦窗口轮询间隔（秒）
# 环境变量：BOCHK_MONITOR_MIDNIGHT_FOCUS_INTERVAL_SECS
midnight_focus_interval_secs = 5

# 夜间时段轮询间隔（秒）
# 环境变量：BOCHK_MONITOR_NIGHT_INTERVAL_SECS
night_interval_secs = 180

# 半点聚焦窗口分钟范围（支持跨小时）
# 环境变量：BOCHK_MONITOR_FOCUS_MINUTE_START / BOCHK_MONITOR_FOCUS_MINUTE_END
focus_minute_start = 25
focus_minute_end = 35

# 夜间时段小时范围（支持跨天）
# 环境变量：BOCHK_MONITOR_NIGHT_HOUR_START / BOCHK_MONITOR_NIGHT_HOUR_END
night_hour_start = 1
night_hour_end = 6

[database]
# 启动时是否执行一次性历史重置（仅清空 slot_events/current_slots）
# 仅在 app_state.history_reset_done != 1 时执行，执行后自动标记完成
# 环境变量：BOCHK_DATABASE_RESET_HISTORY_ON_START
reset_history_on_start = false

[bark]
# Bark 推送地址列表，支持多人通知
# 留空数组表示关闭 Bark 推送（默认）
# 例如: ["https://api.day.app/token_a", "https://api.day.app/token_b"]
# 环境变量：BOCHK_BARK_URLS（使用英文逗号分隔多个地址）
urls = []

[logging]
# 是否将原始接口响应与变化记录额外写入 JSONL 文件，默认关闭
# 建议仅在排查问题时临时开启；常规运行可保持 false，仅看 stdout/stderr
# 环境变量：BOCHK_LOGGING_PERSIST_JSONL
persist_jsonl = false

[web]
# 是否启用内置 Web 状态页，默认启用
# 支持 true/false；环境变量同样支持 1/0、yes/no、on/off
# 环境变量：BOCHK_WEB_ENABLED
enabled = true

# 内置 Web 状态页监听端口，默认 32141
# 程序监听 0.0.0.0（Render 等平台请优先使用 PORT）
# 环境变量优先级：PORT > BOCHK_WEB_PORT
port = 32141
