# BOCHK 预约监控配置
# 本文件可选；若不提供，也可仅依赖默认值 + BOCHK_* 环境变量启动。
# 环境变量优先级高于本文件。

[proxy]
# SOCKS5 代理地址；留空表示直连（默认）
# 推荐使用 socks5h://，由代理端完成 DNS 解析
# 环境变量：BOCHK_PROXY_URL
url = ""

[monitor]
# 请求间隔（秒），默认 30
# 建议根据网络情况控制在 10-30 秒
# 环境变量：BOCHK_MONITOR_INTERVAL_SECS
interval_secs = 30
# 连续失败多少次后发送 Bark 异常告警，默认 5
# 环境变量：BOCHK_MONITOR_MAX_FAIL_COUNT
max_fail_count = 5

[bark]
# Bark 推送地址列表，支持多人通知
# 留空数组表示关闭 Bark 推送（默认）
# 例如: ["https://api.day.app/token_a", "https://api.day.app/token_b"]
# 环境变量：BOCHK_BARK_URLS（使用英文逗号分隔多个地址）
urls = []

[web]
# 是否启用内置 Web 状态页，默认启用
# 支持 true/false；环境变量同样支持 1/0、yes/no、on/off
# 环境变量：BOCHK_WEB_ENABLED
enabled = true

# 内置 Web 状态页监听端口，默认 32141
# 环境变量：BOCHK_WEB_PORT
port = 32141
